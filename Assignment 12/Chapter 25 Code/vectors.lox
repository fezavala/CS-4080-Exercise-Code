fun getX(x, y) { return x; }
fun getY(x, y) { return y; }

fun makeVector(x, y) {
    var vec = x * 1000000 + y;
    return vec;
}

fun vecX(vec) { return vec / 1000000; }
fun vecY(vec) { return vec - (vec / 1000000) * 1000000; }

fun addVectors(a, b) {
    return makeVector(vecX(a) + vecX(b), vecY(a) + vecY(b));
}

var a = makeVector(1, 2);
var b = makeVector(3, 4);

print vecX(a);
print vecY(a);
print vecX(b);
print vecY(b);

var c = addVectors(a, b);
print vecX(c);
print vecY(c);
